# Project13 Environment Variables
# Copy to .env and fill in real values

# Execution
EXECUTION_MODE=paper
TRADING_ENABLED=true
STARTING_CAPITAL_USDC=100
# Set to "I_UNDERSTAND" ONLY when ready for live trading
LIVE_TRADING_CONFIRMATION=

# Risk controls (percent of equity / HWM — scale with portfolio)
MAX_DRAWDOWN_PCT=0.20
DAILY_LOSS_LIMIT_PCT=0.15
KILL_SWITCH_ACTIVE=false

# Polymarket Authentication (needed for live trading only)
POLYMARKET_PRIVATE_KEY=your_private_key_here
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_PASSPHRASE=

# Web Dashboard
DASHBOARD_ENABLED=true
DASHBOARD_PORT=3000
# Set a token to require authentication (leave empty for open access on localhost)
DASHBOARD_AUTH_TOKEN=

# Testing mode (paper-only, lower thresholds for visibility)
TESTING_MODE=false

# Optional overrides
# LOG_LEVEL=INFO
